{
  "name": "jasper-ui",
  "version": "1.3.0",
  "packageManager": "npm@11.6.2",
  "scripts": {
    "postinstall": "patch-package",
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build --configuration production --source-map --localize",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "e2e": "npx playwright test",
    "pw:open": "(cd e2e; docker compose pull && docker compose up --build -d) && npx playwright test --ui && (cd e2e; docker compose down)",
    "pw:open:sqlite": "(cd e2e; docker compose pull && docker compose -f 'docker-compose.yaml' -f 'docker-compose.sqlite.yaml' up --build -d) && npx playwright test --ui && (cd e2e; docker compose -f 'docker-compose.yaml' -f 'docker-compose.sqlite.yaml' down)",
    "pw:ci": "docker compose --profile ci -f 'e2e/docker-compose.yaml' up --build --exit-code-from playwright",
    "pw:ci:sqlite": "docker compose --profile ci -f 'e2e/docker-compose.yaml' -f 'e2e/docker-compose.sqlite.yaml' up --build --exit-code-from playwright"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^22.0.1",
    "@angular/cdk": "^22.0.1",
    "@angular/common": "^22.0.1",
    "@angular/compiler": "^22.0.1",
    "@angular/core": "^22.0.1",
    "@angular/forms": "^22.0.1",
    "@angular/localize": "^22.0.1",
    "@angular/platform-browser": "^22.0.1",
    "@angular/router": "^22.0.1",
    "@angular/service-worker": "^22.0.1",
    "@maplibre/ngx-maplibre-gl": "^21.0.2",
    "@ngx-formly/core": "7.1.0",
    "@stomp/rx-stomp": "^2.4.0",
    "@stomp/stompjs": "^7.3.0",
    "ag-grid-angular": "^35.3.1",
    "ag-grid-community": "^35.1.0",
    "array.prototype.at": "^1.1.3",
    "chess.js": "^1.4.0",
    "clipboard": "^2.0.11",
    "css-flatten": "^2.0.1",
    "d3": "^7.9.0",
    "dompurify": "^3.4.10",
    "europa": "^6.0.0",
    "europa-core": "^6.0.0",
    "file-saver": "^2.0.5",
    "globalthis": "^1.0.4",
    "handlebars": "^4.7.9",
    "he": "^1.2.0",
    "hls.js": "^1.6.16",
    "jsqr": "^1.4.0",
    "jszip": "^3.10.1",
    "jtd": "^0.1.1",
    "katex": "^0.16.47",
    "lodash-es": "^4.18.1",
    "luxon": "^3.7.2",
    "maplibre-gl": "^5.24.0",
    "marked": "^18.0.5",
    "mermaid": "^11.15.0",
    "mobx": "^6.16.1",
    "mobx-angular": "^4.8.0",
    "monaco-editor": "^0.55.1",
    "ngx-markdown": "^22.0.0",
    "ngx-monaco-editor": "^12.0.0",
    "node-diff3": "3.2.1",
    "prismjs": "^1.30.0",
    "qrcode": "^1.5.4",
    "rxjs": "^7.4.0",
    "tslib": "^2.8.1",
    "uuid": "^14.0.0",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zone.js": "~0.16.2"
  },
  "devDependencies": {
    "@angular/build": "^22.0.1",
    "@angular/cli": "^22.0.1",
    "@angular/compiler-cli": "^22.0.0",
    "@ngx-formly/schematics": "7.1.0",
    "@playwright/test": "^1.60.0",
    "@types/chess.js": "^0.13.7",
    "@types/d3": "^7.4.3",
    "@types/file-saver": "^2.0.7",
    "@types/he": "^1.2.3",
    "@types/lodash-es": "^4.17.12",
    "@types/luxon": "^3.7.1",
    "@types/qrcode": "^1.5.6",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.5",
    "jsdom": "^29.1.1",
    "patch-package": "^8.0.1",
    "raw-loader": "^4.0.2",
    "typescript": "~6.0.3",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "@angular/common": "$@angular/common",
    "@angular/core": "$@angular/core",
    "@angular/cdk": "$@angular/cdk",
    "@angular/platform-browser": "$@angular/platform-browser",
    "lodash-es": "$lodash-es",
    "dompurify": "$dompurify",
    "maplibre-gl": "$maplibre-gl",
    "marked": "$marked",
    "mermaid": "$mermaid",
    "katex": "$katex",
    "uuid": "$uuid",
    "zone.js": "$zone.js",
    "mobx": "$mobx",
    "rxjs": "$rxjs",
    "monaco-editor": "$monaco-editor",
    "d3": "$d3"
  },
  "browser": {
    "fs": false,
    "os": false,
    "path": false
  }
}
